# Copy this file to .env and fill in the values.
# Never commit .env to git.

# Database
DATABASE_URL=postgresql+asyncpg://nelvra:nelvra@localhost:5432/nelvra
REDIS_URL=redis://localhost:6379

# Authentication — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-random-secret-key

# Shared secret between Next.js dashboard and the FastAPI backend
INTERNAL_SECRET=change-this-to-a-random-secret-key

# AI Services (required for Phase 2 features — quality scoring, drift detection)
ANTHROPIC_API_KEY=sk-ant-xxx

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
